# MillionsKeeper v2 — Environment Variables
# Скопируй этот файл в .env и заполни своими значениями:
#   cp .env.example .env

# ── MetaTrader 5 ──────────────────────────────────────────────────
# Те же данные, что вводишь при входе в терминал MT5
MT5_LOGIN=123456789
MT5_PASSWORD=your_mt5_password
MT5_SERVER=BrokerName-Real

# ── PostgreSQL ────────────────────────────────────────────────────
# docker compose up запускает postgres с этими параметрами
POSTGRES_USER=mk
POSTGRES_PASSWORD=mk
POSTGRES_DB=millionskeeper
POSTGRES_URL=postgresql+asyncpg://mk:mk@localhost:5432/millionskeeper

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth (JWT) ────────────────────────────────────────────────────
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-64-char-hex-string
JWT_EXPIRE_HOURS=24

# ── Trading defaults ──────────────────────────────────────────────
# scalp_timeframe: M1=1, M5=5, M15=15, H1=16385 (mt5 константы)
SCALP_TIMEFRAME=1
TREND_TIMEFRAME=16385
DEFAULT_RISK_PERCENT=1.0
MAX_OPEN_POSITIONS=5

# Poll intervals (seconds)
POLL_INTERVAL_MARKET=10.0
POLL_INTERVAL_POSITION=5.0
POLL_INTERVAL_ACCOUNT=30.0
POLL_INTERVAL_HISTORY=300.0

# ── Web ───────────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8080
# Разрешённые CORS origins (через запятую для списка)
CORS_ORIGINS=["http://localhost:5173","http://localhost:8080","http://localhost:3000"]

# ── Feature flags ─────────────────────────────────────────────────
ENABLE_REDIS_CACHE=true
LOG_LEVEL=INFO

# ── Docker prod (docker-compose.prod.yml) ─────────────────────────
# Адрес нативного backend из контейнера nginx
# На Windows Docker Desktop: host.docker.internal резолвится автоматически
BACKEND_HOST=host.docker.internal
BACKEND_PORT=8080
